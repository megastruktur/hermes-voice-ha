[Unit]
Description=MARC voice — Wyoming bridge for Soniox real-time TTS
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.hermes/.env
WorkingDirectory=%h/projects/marc-voice/wyoming-soniox-tts
ExecStart=%h/projects/marc-voice/wyoming-soniox-tts/venv/bin/python -m wyoming_soniox_tts --uri tcp://0.0.0.0:10400
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
